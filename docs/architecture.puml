@startuml KI-Journalgranskaren Architecture

package "KI-Journalgranskaren (Frontend React SPA)" {
  [App] --> [SecurityNotice] : Renders privacy notice
  [App] --> [ImportSummary] : Displays parsed statistics & warnings
  [App] --> [NoteList] : Renders scrolling viewport with shaders
  [NoteList] --> [Note] : Renders patient note cards
  [Note] --> [NoteHeader] : Renders metadata (Date, Author)
  [Note] --> [MarkdownTypography] : Renders parsed journal body text

  [App] ..> [parser/index] : Uses getParserForFile()
  [parser/index] --> [CsvParser] : Selector
  [parser/index] --> [XlsxParser] : Selector

  [CsvParser] ..> [aliasMatcher] : Maps headers & validates
  [XlsxParser] ..> [aliasMatcher] : Maps headers & validates
  
  [aliasMatcher] ..> [types/chart] : Returns ParsedChartFile

  [App] ..> [db] : Records reviewer actions
  [PatientOverview] ..> [db] : Verifies & exports audit log
  [db] --> [computeSHA256] : SHA-256 (Web Crypto)
}

database "Local Browser Storage\n(IndexedDB: ki_audit_db)" as AuditDB {
  [Audit Log Hash Chain] as Chain
}

[db] --> Chain : Append-only, prevHash-linked entries
Chain ..> [db] : verifyAuditLogChain() recomputes hashes

database "Local File System\n(Secure Offline Computer)" as LocalFS {
  [CSV Journal Export] as CSV
  [Excel Journal Export] as XLSX
}

[App] <.. CSV : File input selection
[App] <.. XLSX : File input selection

package "Desktop Wrapper (Tauri Release Build)" {
  [Native OS Window] as Win
  [WebView2 / WebKit] as Webview
  Win --> Webview : Host container
  Webview ..> [App] : Renders React SPA
}

@enduml
